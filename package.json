{
    "name": "ssms-backend",
    "version": "1.0.0",
    "description": "SMS - School Management System - Enterprise Backend",
    "main": "dist/server.js",
    "scripts": {
        "dev": "NODE_OPTIONS=--max-old-space-size=4096 nodemon --watch src --ext ts,json --exec ts-node --transpile-only src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "lint": "eslint . --ext .ts",
        "format": "prettier --write \"src/**/*.ts\"",
        "test": "jest --watchAll",
        "seed:load-test": "ts-node --transpile-only src/scripts/seed-load-test-school.ts",
        "seed:erase-load-test": "ts-node --transpile-only src/scripts/erase-load-test-school.ts"
    },
    "keywords": [
        "school",
        "erp",
        "saas",
        "multi-tenant",
        "sms"
    ],
    "author": "Shagun Systems",
    "license": "PROPRIETARY",
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@types/bcryptjs": "^2.4.6",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^1.4.13",
        "@types/node": "^20.19.33",
        "bcryptjs": "^2.4.3",
        "bullmq": "^5.75.2",
        "cloudinary": "^1.41.0",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "csv-parser": "^3.0.0",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.1.5",
        "express-status-monitor": "^1.3.4",
        "express-validator": "^7.0.1",
        "firebase-admin": "^12.7.0",
        "googleapis": "^171.4.0",
        "helmet": "^7.1.0",
        "ioredis": "^5.10.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "multer": "^1.4.5-lts.1",
        "pdfkit": "^0.13.0",
        "razorpay": "^2.9.6",
        "socket.io": "^4.8.3",
        "twilio": "^5.12.2",
        "winston": "^3.11.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cookie-parser": "^1.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.25",
        "@types/express-mongo-sanitize": "^1.3.2",
        "@types/express-status-monitor": "^1.3.3",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^1.4.13",
        "@types/node": "^20.19.33",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.1.1",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3"
    }
